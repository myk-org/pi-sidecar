{
  "name": "@myk-org/pi-sidecar",
  "version": "1.1.2",
  "description": "Standalone HTTP sidecar wrapping the Pi coding agent SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/myk-org/pi-sidecar"
  },
  "keywords": ["pi", "sidecar", "ai", "coding-agent", "llm"],
  "engines": {
    "node": ">=22.19.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "postbuild": "rm -f dist/.gitignore",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test tests/test_ts/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@earendil-works/pi-ai": "^0.79.0",
    "pi-orchestrator-config": "myk-org/pi-config#v3.1.0",
    "pi-vertex-claude": "myk-org/pi-vertex-claude#v0.2.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0"
  },
  "overrides": {
    "undici": ">=6.27.0",
    "uuid": ">=11.1.1"
  }
}
